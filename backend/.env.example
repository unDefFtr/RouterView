# Browser origin accepted for authenticated mutations and WebSocket upgrades.
# Plain HTTP is accepted only for localhost development.
PUBLIC_ORIGIN=http://localhost:5173

# Comma-separated proxy source networks allowed to supply X-Real-IP.
# Leave empty for direct development access; never list client/LAN networks.
TRUSTED_PROXY_CIDRS=

# Path to a file containing exactly 32 random bytes. The path is resolved from
# the process working directory. Never put key bytes directly in this file.
ROUTERVIEW_MASTER_KEY_FILE=../secrets/routerview-dev-master-key

# Optional standard OpenID Connect login. Local administrator login remains
# available. The client secret is accepted only through the named file.
OIDC_ENABLED=false
# OIDC_ISSUER_URL=https://idp.example.com/application/o/routerview
# OIDC_CLIENT_ID=routerview-dev
# OIDC_CLIENT_SECRET_FILE=../secrets/routerview-oidc-client-secret
# OIDC_PROVIDER_NAME=Company SSO
# OIDC_GROUPS_CLAIM=groups
# OIDC_VIEWER_GROUP=routerview-viewers
# OIDC_ADMIN_GROUP=routerview-admins
# OIDC_ADDITIONAL_SCOPES=
# OIDC_CA_FILE=../secrets/routerview-oidc-ca.pem

# Deployment policy for RouterOS management destinations. Plain RouterOS HTTP
# must also be explicitly enabled here before the WebUI can select it.
ROUTER_MANAGEMENT_CIDRS=192.168.88.0/24
ALLOW_INSECURE_ROUTER_HTTP=false

# Configure the RouterOS endpoint, TLS compatibility, polling and probe
# intervals, retention periods, and theme in the first-run WebUI. Legacy
# environment overrides remain supported but are intentionally omitted here.

# Local service state.
DB_PATH=traffic.db
SERVER_PORT=3001
SETUP_PORT=3002
SETUP_TOKEN_FILE=/tmp/routerview-setup-token
RUST_LOG=info,routerview_backend=debug
