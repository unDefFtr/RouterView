# RouterOS connection
ROUTEROS_HOST=192.168.88.1
ROUTEROS_PORT=80
ROUTEROS_SCHEME=http
ROUTEROS_USERNAME=admin
ROUTEROS_PASSWORD=your-password-here
# ROUTEROS_INSECURE_TLS=true  # only needed when ROUTEROS_SCHEME=https

# Polling intervals (seconds)
POLL_INTERVAL_SECS=3
PROBE_INTERVAL_SECS=60

# Backend server
SERVER_PORT=3001
RUST_LOG=info,routerview_backend=debug
