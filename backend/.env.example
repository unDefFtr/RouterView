# Browser origin accepted for authenticated mutations and WebSocket upgrades.
# Plain HTTP is accepted only for localhost development.
PUBLIC_ORIGIN=http://localhost:5173

# Path to a file containing exactly 32 random bytes. The path is resolved from
# the process working directory. Never put key bytes directly in this file.
ROUTERVIEW_MASTER_KEY_FILE=../secrets/routerview-dev-master-key

# Router endpoint defaults. Enter the RouterOS password through the
# authenticated settings UI so it is encrypted before storage.
ROUTER_TYPE=routeros
ROUTER_HOST=192.168.88.1
ROUTER_PORT=443
ROUTER_SCHEME=https
ROUTER_USERNAME=admin
ROUTER_INSECURE_TLS=false
ROUTER_MANAGEMENT_CIDRS=192.168.88.0/24
ALLOW_INSECURE_ROUTER_HTTP=false

# Polling and retention.
POLL_INTERVAL_SECS=3
PROBE_INTERVAL_SECS=60
DB_RAW_RETENTION_DAYS=7
DB_TOTAL_RETENTION_DAYS=90

# Local service state.
DB_PATH=traffic.db
SERVER_PORT=3001
SETUP_PORT=3002
SETUP_TOKEN_FILE=/tmp/routerview-setup-token
RUST_LOG=info,routerview_backend=debug
