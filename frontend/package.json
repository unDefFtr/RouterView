{
  "name": "routerview-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm typecheck && vite build && pnpm bundle:check",
    "bundle:check": "node scripts/check-bundle-budget.mjs",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "echarts": "^5.6.0",
    "feather-icons": "^4.29.2",
    "misans": "^4.1.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "typescript": "~5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.2.0"
  }
}
