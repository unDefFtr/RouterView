# HTTPS name presented by Caddy's local CA. Add it to local DNS or hosts files.
ROUTERVIEW_DOMAIN=routerview.local

# Published images are public and do not require a GHCR login. Uncomment both
# lines to deploy v0.2.1 without building locally. Keep the versions identical.
# ROUTERVIEW_BACKEND_IMAGE=ghcr.io/undefftr/routerview-backend:0.2.1
# ROUTERVIEW_CADDY_IMAGE=ghcr.io/undefftr/routerview-caddy:0.2.1

# Limit published ports to a LAN address when the host has multiple interfaces.
ROUTERVIEW_HTTP_BIND=0.0.0.0
ROUTERVIEW_HTTPS_BIND=0.0.0.0

# The default is Caddy's fixed address on the private Compose app network.
# Change this only when the reverse-proxy topology in compose.yaml also changes.
TRUSTED_PROXY_CIDRS=172.31.254.2/32

# Host-side file containing exactly 32 random bytes. Keep its parent directory
# mode 0700 and the file mode 0444 so the non-root container can read a local
# Compose file-backed secret. Never commit this file.
ROUTERVIEW_MASTER_KEY_SOURCE=./secrets/routerview_master_key

# Only router targets inside these networks are accepted by hardened backends.
ROUTER_MANAGEMENT_CIDRS=192.168.88.0/24
ALLOW_INSECURE_ROUTER_HTTP=false

# Initial router endpoint. The password is entered through the authenticated UI.
ROUTER_TYPE=routeros
ROUTER_HOST=192.168.88.1
ROUTER_PORT=443
ROUTER_SCHEME=https
ROUTER_USERNAME=admin
ROUTER_INSECURE_TLS=false

POLL_INTERVAL_SECS=3
PROBE_INTERVAL_SECS=60
DB_RAW_RETENTION_DAYS=7
DB_TOTAL_RETENTION_DAYS=90
RUST_LOG=info

# OIDC remains disabled when only compose.yaml is used. To enable one standard
# OpenID Connect provider, uncomment COMPOSE_FILE and all required values below.
# The callback registered at the provider must be exactly:
# https://<ROUTERVIEW_DOMAIN>/api/auth/oidc/callback
# COMPOSE_FILE=compose.yaml:compose.oidc.yaml
# OIDC_ISSUER_URL=https://idp.example.com/application/o/routerview
# OIDC_CLIENT_ID=routerview
# OIDC_CLIENT_SECRET_SOURCE=./secrets/routerview_oidc_client_secret
# OIDC_PROVIDER_NAME=Company SSO
# OIDC_GROUPS_CLAIM=groups
# OIDC_VIEWER_GROUP=routerview-viewers
# OIDC_ADMIN_GROUP=routerview-admins
# OIDC_ADDITIONAL_SCOPES=

# For a provider signed by a private CA, append compose.oidc-ca.yaml to
# COMPOSE_FILE and set the host-side PEM bundle. Do not disable TLS validation.
# COMPOSE_FILE=compose.yaml:compose.oidc.yaml:compose.oidc-ca.yaml
# OIDC_CA_SOURCE=./secrets/routerview_oidc_ca.pem
