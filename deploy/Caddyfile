{
	admin off
	skip_install_trust
	log {
		format json
		level INFO
	}
	servers {
		protocols h1 h2
	}
}

http://{$ROUTERVIEW_DOMAIN:routerview.local} {
	route {
		header -Server
		redir https://{$ROUTERVIEW_DOMAIN:routerview.local}{uri} 308
	}
}

{$ROUTERVIEW_DOMAIN:routerview.local} {
	tls internal
	encode zstd gzip

	header {
		-Server
		Content-Security-Policy "default-src 'self'; base-uri 'self'; connect-src 'self'; font-src 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self' data:; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'"
		Cross-Origin-Opener-Policy "same-origin"
		Permissions-Policy "camera=(), geolocation=(), microphone=(), payment=(), usb=()"
		Referrer-Policy "no-referrer"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
	}

	@immutable path /assets/*
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	route {
		handle /api/auth/setup {
			respond 404
		}

		handle /api/* {
			reverse_proxy backend:3001 {
				header_up X-Real-IP {http.request.remote.host}
			}
		}

		handle /ws {
			reverse_proxy backend:3001 {
				header_up X-Real-IP {http.request.remote.host}
			}
		}

		handle {
			root * /srv
			route {
				try_files {path} /index.html
				@index path /index.html
				header @index Cache-Control "no-cache, no-store, must-revalidate"
				file_server
			}
		}
	}
}
